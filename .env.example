# 必填: 加密主密钥 (首次使用请生成一个随机字符串，之后不可更改)
POLYTRAD_MASTER_KEY=change-me-to-a-random-string-at-least-32-chars

# 数据库 (默认 SQLite)
DATABASE_URL=sqlite+aiosqlite:///./polytrad.db

# JWT 密钥
JWT_SECRET=change-me-to-another-random-string

# 管理员初始账户 (首次启动自动创建)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Polymarket 链 ID (137=主网, 80002=测试网)
POLYMARKET_CHAIN_ID=137

# 服务端口
PORT=8000
